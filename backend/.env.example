# ============================================================
# flux-rag 환경 설정 예시
# 복사 후 .env로 사용: cp .env.example .env
# ============================================================

# --- LLM 프로바이더 ---
# 로컬 개발: ollama / 운영(RunPod): vllm
DEFAULT_LLM_PROVIDER=vllm
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
VLLM_BASE_URL=http://localhost:8002/v1

# --- 벡터 DB ---
VECTORSTORE_TYPE=milvus_lite
MILVUS_STORE_URI=./data/milvus.db
# Milvus Standalone: MILVUS_STORE_URI=http://localhost:19530

# --- 인증 ---
AUTH_ENABLED=true

# --- 캐시 ---
CACHE_ENABLED=true
REDIS_URL=redis://localhost:6379/0

# --- 청킹 ---
CHUNK_STRATEGY=adaptive
CHUNK_SIZE=800
CHUNK_OVERLAP=80

# --- 검색 ---
RETRIEVAL_TOP_K=30
RERANK_TOP_N=7
VECTOR_WEIGHT=0.7
BM25_WEIGHT=0.3
RETRIEVAL_SCORE_THRESHOLD=0.0
CONTEXT_MAX_CHUNKS=7
USE_RERANK=false
BM25_K1=1.5
BM25_B=0.75

# --- LLM 생성 ---
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.2

# --- 고급 RAG ---
QUERY_EXPANSION_ENABLED=false
MULTI_QUERY_ENABLED=false
MULTI_QUERY_COUNT=3
SELF_RAG_ENABLED=true
SELF_RAG_MAX_RETRIES=1
AGENTIC_RAG_ENABLED=false

# --- 신뢰도 ---
CONFIDENCE_LOW=0.3
CONFIDENCE_HIGH=0.8
FEW_SHOT_MAX_EXAMPLES=2

# --- OCR ---
# UPSTAGE_API_KEY=your-key-here
OCR_PROVIDER=cloud

# --- 문서 동기화 ---
SYNC_ENABLED=false
SYNC_CRON=0 2 * * *
